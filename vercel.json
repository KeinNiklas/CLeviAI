{
    "version": 2,
    "functions": {
        "api/main.py": {
            "runtime": "@vercel/python@6.12.0"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ]
}