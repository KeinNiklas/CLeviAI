{
    "version": 2,
    "functions": {
        "api/index.py": {
            "runtime": "@vercel/python@6.12.0",
            "excludeFiles": "frontend/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ]
}